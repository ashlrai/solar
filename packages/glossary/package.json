{
  "name": "@ashlrai/glossary",
  "version": "0.1.0",
  "description": "Open glossary of US + Canadian solar permitting terms — NEC clauses, AHJ jargon, incentive programs. Plain-English first.",
  "license": "MIT",
  "homepage": "https://solar.ashlr.ai/glossary",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashlrai/solar.git",
    "directory": "packages/glossary"
  },
  "bugs": "https://github.com/ashlrai/solar/issues",
  "author": "Ashlr.ai <founders@ashlr.ai>",
  "keywords": ["solar", "glossary", "NEC", "permitting"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsup": "8.3.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
