{
  "name": "ashlrai-solar-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source companion to ashlr.ai — solar permitting knowledge graph + docs",
  "license": "SEE LICENSE + DATA_LICENSE",
  "homepage": "https://solar.ashlr.ai",
  "repository": "github:ashlrai/solar",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify:ahj": "tsx scripts/verify-ahj.ts",
    "generate:llms-txt": "tsx scripts/generate-llms-txt.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter='./packages/*' && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.28.1",
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "turbo": "2.3.4",
    "typescript": "5.7.3"
  }
}
